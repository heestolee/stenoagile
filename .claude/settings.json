{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc -b",
            "description": "파일 수정 후 타입체크 (CI와 동일)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc -b",
            "description": "파일 수정 후 타입체크 (CI와 동일)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\notify.wav').PlaySync()\"",
            "description": "작업 완료 시 Windows 알림음"
          }
        ]
      }
    ]
  }
}
